{
  "name": "@acepe/claude-agent-acp",
  "private": true,
  "version": "0.1.0",
  "description": "Acepe adapter for @zed-industries/claude-agent-acp",
  "main": "dist/index.mjs",
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "build:binary": "bun build src/static-entry.ts --compile --define 'process.env.CLAUDE_AGENT_ACP_IS_SINGLE_FILE_BUN=\"true\"' --outfile dist/claude-agent-acp",
    "build:tsc": "tsc",
    "prepare": "bun run build:binary",
    "start": "node dist/index.mjs",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "0.15.0",
    "@zed-industries/claude-agent-acp": "0.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "25.0.3",
    "esbuild": "0.25.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16"
  },
  "patchedDependencies": {
    "@zed-industries/claude-agent-acp@0.21.0": "patches/@zed-industries%2Fclaude-agent-acp@0.21.0.patch"
  }
}
