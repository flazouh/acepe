	"semanticHighlighting": true,
	"semanticTokenColors": {
		"enumMember": {
			"foreground": "#1a1a1a"
		},
		"variable.constant": {
			"foreground": "#0D9488"
		},
		"variable.defaultLibrary": {
			"foreground": "#1a1a1a"
		},
		"variable.defaultLibrary.globalScope": {
			"foreground": "#1a1a1a"
		},
		"class.typeHint": "#0D9488",
		"variable.declaration.readonly:cpp": "#1a1a1a",
		"variable.declaration.readonly:c": "#1a1a1a",
		"variable.readonly:cpp": "#1a1a1a",
		"variable.readonly:c": "#1a1a1a",
		"variable.other.property.ts": "#6366F1",
		"variable.other.property": "#6366F1",
		"variable.other": "#6366F1",
		"method.declaration": {
			"foreground": "#C2410C",
			"fontStyle": "bold"
		},
		"meta.definition.property.ts": {
			"foreground": "#6366F1",
			"fontStyle": "bold"
		},
		"entity.name.function": {
			"foreground": "#B45309"
		},
		"function.builtin": "#0D9488",
		"class.builtin": "#0D9488",
		"class.declaration:python": "#2563EB",
		"support.variable.property": "#6366F1",
		"class.decorator.builtin:python": "#16A34A",
		"function.declaration": {
			"foreground": "#C2410C",
			"fontStyle": "bold"
		},
		"operatorOverload": "#1a1a1a",
		"memberOperatorOverload": "#1a1a1a",
		"namespace:cpp": "#2563EB",
		"variable.global:cpp": "#16A34A",
		"variable.global:c": "#16A34A",
		"type:cpp": "#2563EB",
		"function": "#B45309",
		"class:python": {
			"foreground": "#B45309",
			"fontStyle": ""
		},
		"*.decorator:python": {
			"foreground": "#16A34A",
			"fontStyle": ""
		},
		"method:python": {
			"foreground": "#B45309",
			"fontStyle": ""
		},
		"method:cpp": {
			"foreground": "#2563EB",
			"fontStyle": ""
		},
		"selfParameter": "#BE185D",
		"property:cpp": "#7C3AED",
		"variable:javascript": "#1a1a1a",
		"property.declaration:cpp": "#7C3AED",
		"property.declaration:c": "#7C3AED",
		"type:c": "#2563EB",
		"property:c": "#7C3AED",
		"function:cmake": "#2563EB",
		"builtinConstant.readonly.builtin:python": "#0D9488"
	},
	"tokenColors": [
		{
			"name": "Comments",
			"scope": "comment, punctuation.definition.comment",
			"settings": {
				"fontStyle": "italic",
				"foreground": "#6B7280"
			}
		},
		{
			"name": "Keywords",
			"scope": "keyword",
			"settings": {
				"foreground": "#0D9488"
			}
		},
		{
			"name": "Storage",
			"scope": "storage",
			"settings": {
				"foreground": "#0D9488"
			}
		},
		{
			"name": "Strings",
			"scope": "string",
			"settings": {
				"foreground": "#DB2777"
			}
		},
		{
			"name": "Functions",
			"scope": ["entity.name.function", "meta.require", "support.function", "variable.function"],
			"settings": {
				"foreground": "#C2410C"
			}
		},
		{
			"name": "Classes",
			"scope": "support.class, entity.name.type.class",
			"settings": {
				"foreground": "#2563EB"
			}
		},
		{
			"name": "Variables",
			"scope": "variable",
			"settings": {
				"foreground": "#1a1a1a"
			}
		},
		{
			"name": "Constants",
			"scope": "constant.numeric",
			"settings": {
				"foreground": "#B45309"
			}
		},
		{
			"name": "Attributes",
			"scope": "entity.other.attribute-name",
			"settings": {
				"foreground": "#7C3AED"
			}
		},
		{
			"name": "Tags",
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#2563EB"
			}
		},
		{
			"name": "JSON Property Name",
			"scope": "support.type.property-name.json",
			"settings": {
				"foreground": "#0D9488"
			}
		},
		{
			"name": "Operators",
			"scope": "keyword.operator",
			"settings": {
				"foreground": "#1a1a1a"
			}
		},
		{
			"name": "Language variables",
			"scope": "variable.language",
			"settings": {
				"foreground": "#BE185D"
			}
		},
		{
			"name": "Type Name",
			"scope": "entity.name.type",
			"settings": {
				"foreground": "#C2410C"
			}
		},
		{
			"name": "Punctuation Definition Tag",
			"scope": "punctuation.definition.tag",
			"settings": {
				"foreground": "#6B7280",
				"fontStyle": ""
			}
		},
		{
			"name": "Punctuation Definition String",
			"scope": "punctuation.definition.string.begin,punctuation.definition.string.end",
			"settings": {
				"foreground": "#DB2777"
			}
		}
	]
}
