#!/bin/sh

NAME="$(git config user.name || true)"
EMAIL="$(git config user.email || true)"

if [ "$NAME" = "Test" ] || [ "$NAME" = "TestCopilot" ] || [ "$EMAIL" = "test@test.com" ]; then
	echo "Error: refusing to commit with placeholder Git identity:"
	echo "  $NAME <$EMAIL>"
	echo
	echo "Configured identity sources:"
	git config --show-origin --get-regexp '^user\\.(name|email)$' || true
	echo
	echo "Fix this repo with:"
	echo "  git config --local --unset-all user.name"
	echo "  git config --local --unset-all user.email"
	exit 1
fi
