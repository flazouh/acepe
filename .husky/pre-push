#!/bin/sh

# Determine what's being pushed so we don't run unrelated jobs.
# Read the standard pre-push stdin protocol to collect the ranges being pushed.
# Fallback: if stdin is empty (e.g., manual invocation), compare HEAD to origin/main.

ranges=""
while read -r _local_ref local_sha _remote_ref remote_sha; do
	[ -z "$local_sha" ] && continue
	zero="0000000000000000000000000000000000000000"
	if [ "$local_sha" = "$zero" ]; then
		continue
	fi
	if [ "$remote_sha" = "$zero" ] || [ -z "$remote_sha" ]; then
		# New branch — diff against the upstream default.
		base="$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "")"
		[ -n "$base" ] && ranges="$ranges $base..$local_sha"
	else
		ranges="$ranges $remote_sha..$local_sha"
	fi
done

if [ -z "$ranges" ]; then
	base="$(git merge-base HEAD origin/main 2>/dev/null || echo "")"
	if [ -n "$base" ]; then
		ranges="$base..HEAD"
	fi
fi

if [ -n "$ranges" ]; then
	# shellcheck disable=SC2086
	CHANGED="$(git diff --name-only $ranges 2>/dev/null | sort -u)"
else
	CHANGED=""
fi

# If we couldn't determine changed files, fall back to running everything so we don't skip checks silently.
if [ -z "$CHANGED" ]; then
	echo "pre-push: could not determine changed files; running all checks"
	RUN_DESKTOP_FRONTEND=1
	RUN_WEBSITE=1
	RUN_BACKEND=1
else
	RUN_DESKTOP_FRONTEND=0
	RUN_WEBSITE=0
	RUN_BACKEND=0

	# Desktop frontend: TS/Svelte/JS/config under packages/desktop but NOT src-tauri
	if printf "%s\n" "$CHANGED" | grep -qE '^packages/desktop/(?!src-tauri/)' 2>/dev/null \
		|| printf "%s\n" "$CHANGED" | grep -E '^packages/desktop/' | grep -qvE '^packages/desktop/src-tauri/'; then
		RUN_DESKTOP_FRONTEND=1
	fi
	# Shared UI package affects desktop + website
	if printf "%s\n" "$CHANGED" | grep -qE '^packages/ui/'; then
		RUN_DESKTOP_FRONTEND=1
		RUN_WEBSITE=1
	fi
	# Website
	if printf "%s\n" "$CHANGED" | grep -qE '^packages/website/'; then
		RUN_WEBSITE=1
	fi
	# Backend: Rust sources, Cargo files, Tauri config
	if printf "%s\n" "$CHANGED" | grep -qE '^(packages/desktop/src-tauri/|Cargo\.(toml|lock)$)'; then
		RUN_BACKEND=1
	fi
	# Root-level config changes (package.json, bun.lock, tsconfig, lint/format configs) — run frontends to be safe
	if printf "%s\n" "$CHANGED" | grep -qE '^(package\.json|bun\.lock|tsconfig.*\.json|biome\.json|\.husky/)'; then
		RUN_DESKTOP_FRONTEND=1
		RUN_WEBSITE=1
	fi
fi

echo "pre-push: desktop=$RUN_DESKTOP_FRONTEND website=$RUN_WEBSITE backend=$RUN_BACKEND"

FRONTEND_PID=""
WEBSITE_PID=""
BACKEND_PID=""

DESKTOP_FRONTEND_CHANGED=""
WEBSITE_CHANGED=""

if [ -n "$CHANGED" ]; then
	DESKTOP_FRONTEND_CHANGED="$(printf "%s\n" "$CHANGED" | grep -E '^packages/desktop/' | grep -vE '^packages/desktop/src-tauri/' | sed 's#^packages/desktop/##' || true)"
	WEBSITE_CHANGED="$(printf "%s\n" "$CHANGED" | grep -E '^packages/website/' | sed 's#^packages/website/##' || true)"
fi

if [ "$RUN_DESKTOP_FRONTEND" = "1" ]; then
	(
		cd packages/desktop &&
			export PATH="$HOME/.bun/bin:$PATH" &&
			bun run check &&
			bun run check:svelte &&
			if [ -n "$DESKTOP_FRONTEND_CHANGED" ]; then
				printf "%s\n" "$DESKTOP_FRONTEND_CHANGED" | xargs bunx biome check --diagnostic-level=error
			fi &&
			bun test
	) &
	FRONTEND_PID=$!
fi

if [ "$RUN_WEBSITE" = "1" ]; then
	(
		cd packages/website &&
			export PATH="$HOME/.bun/bin:$PATH" &&
			bun run check &&
			if [ -n "$WEBSITE_CHANGED" ]; then
				printf "%s\n" "$WEBSITE_CHANGED" | xargs bunx biome check --diagnostic-level=error
			fi &&
			bun run test
	) &
	WEBSITE_PID=$!
fi

if [ "$RUN_BACKEND" = "1" ]; then
	(cd packages/desktop/src-tauri && . ~/.cargo/env && cargo check && cargo test -- --skip claude_history::export_types) &
	BACKEND_PID=$!
fi

FRONTEND_STATUS=0
WEBSITE_STATUS=0
BACKEND_STATUS=0

if [ -n "$FRONTEND_PID" ]; then
	wait $FRONTEND_PID
	FRONTEND_STATUS=$?
fi

if [ -n "$WEBSITE_PID" ]; then
	wait $WEBSITE_PID
	WEBSITE_STATUS=$?
fi

if [ -n "$BACKEND_PID" ]; then
	wait $BACKEND_PID
	BACKEND_STATUS=$?
fi

[ $FRONTEND_STATUS -eq 0 ] && [ $WEBSITE_STATUS -eq 0 ] && [ $BACKEND_STATUS -eq 0 ]
