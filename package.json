{
	"name": "acepe",
	"private": true,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/flazouh/acepe.git"
	},
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/flazouh"
	},
	"workspaces": ["packages/*"],
	"scripts": {
		"audit": "bun audit --audit-level high",
		"check:dead-code": "bun scripts/dead-code/find-dead-code.ts --strict",
		"dead-code:apply": "bun scripts/dead-code/apply-dead-code.ts",
		"dead-code:apply:force": "bun scripts/dead-code/apply-dead-code.ts --apply",
		"hooks:install": "lefthook install",
		"hooks:pre-commit": "lefthook run pre-commit",
		"hooks:pre-push": "lefthook run pre-push",
		"install:source": "bash scripts/install-from-source.sh",
		"prepare": "lefthook install",
		"test:install-source": "bash scripts/__tests__/install-from-source.test.sh",
		"test": "bun run test:install-source && bun scripts/forbid-structural-tests.ts packages && bun run --cwd packages/ui test && bun run --cwd packages/desktop test && bun run --cwd packages/website test"
	},
	"engines": {
		"node": "20.x"
	},
	"devDependencies": {
		"lefthook": "2.1.10"
	},
	"dependencies": {
		"@babel/parser": "^8.0.4",
		"@babel/traverse": "^8.0.4",
		"@babel/types": "^8.0.4",
		"@types/babel__traverse": "^7.28.0",
		"neverthrow": "^8.2.0",
		"vaul-svelte": "^1.0.0-next.7",
		"zod": "^4.2.1"
	},
	"overrides": {
		"esbuild": "0.28.1",
		"kysely": "0.29.2",
		"lodash-es": "4.18.1",
		"picomatch": "4.0.4",
		"runed": "0.35.1"
	}
}
